<Window x:Class="NuekProdFO.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NuekProdFO"
        mc:Ignorable="d"
        Title="NuekProdFO - Procesador de Tickets"
        Height="820"
        Width="1280"
        MinHeight="700"
        MinWidth="1000">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F0FDFA" Offset="0" />
                <GradientStop Color="#FFF1F2" Offset="0.6" />
                <GradientStop Color="#FFFBEB" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="20" Padding="18" CornerRadius="16" Background="#E6FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Automatizacion de Tickets desde Excel" FontSize="30" FontWeight="SemiBold" Foreground="#0F766E" />
                    <TextBlock Text="Carga varios archivos, captura ticket/paquete/responsable y envia notificaciones por correo." FontSize="15" Margin="0,6,0,0" Foreground="#44403C" />
                </StackPanel>

                <Border Grid.Column="1" Padding="12,6" CornerRadius="14" Background="#14FB7185" VerticalAlignment="Top">
                    <TextBlock x:Name="TxtStatus" Text="Listo" FontWeight="Bold" Foreground="#9F1239" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="1) Archivos Excel" FontSize="18" FontWeight="SemiBold" Foreground="#0F766E" />
                            <TextBlock Text="Selecciona multiples archivos .xlsx/.xlsm" Margin="0,4,0,10" Foreground="#57534E" />

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Seleccionar archivos" Click="SelectFiles_Click" />
                                <Button Content="Procesar datos" Click="ProcessFiles_Click" Background="{StaticResource SecondaryBrush}" BorderBrush="#BE123C" />
                            </StackPanel>

                            <TextBlock x:Name="TxtFileCount" Text="0 archivos seleccionados" Foreground="#57534E" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="2) Configuracion de celdas" FontSize="18" FontWeight="SemiBold" Foreground="#0F766E" />
                            <TextBlock Text="Define hoja y celdas para extraer los campos." Margin="0,4,0,10" Foreground="#57534E" />

                            <TextBlock Text="Nombre de hoja (opcional)" />
                            <TextBox x:Name="TxtSheetName" ToolTip="Ejemplo: Hoja1" />

                            <TextBlock Text="Celda numero de ticket" />
                            <TextBox x:Name="TxtTicketCell" Text="D8" />

                            <TextBlock Text="Celda nombre del paquete" />
                            <TextBox x:Name="TxtPackageCell" Text="B59" />

                            <TextBlock Text="Celda responsable solicitud" />
                            <TextBox x:Name="TxtRequesterCell" Text="D10" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14">
                        <StackPanel>
                            <TextBlock Text="3) Configuracion SMTP" FontSize="18" FontWeight="SemiBold" Foreground="#0F766E" />
                            <TextBlock Text="Ingresa datos de correo para enviar notificaciones por cada ticket." Margin="0,4,0,10" Foreground="#57534E" />

                            <TextBlock Text="Servidor SMTP" />
                            <TextBox x:Name="TxtSmtpHost" ToolTip="smtp.empresa.com" />

                            <TextBlock Text="Puerto" />
                            <TextBox x:Name="TxtSmtpPort" Text="587" />

                            <CheckBox x:Name="ChkSsl" Content="Usar SSL/TLS" IsChecked="True" Margin="0,4,0,10" />

                            <TextBlock Text="Usuario" />
                            <TextBox x:Name="TxtSmtpUser" />

                            <TextBlock Text="Contrasena" />
                            <PasswordBox x:Name="TxtSmtpPassword" />

                            <TextBlock Text="Correo remitente" />
                            <TextBox x:Name="TxtFrom" ToolTip="no-reply@empresa.com" />

                            <TextBlock Text="Destinatarios (separados por ; o ,)" />
                            <TextBox x:Name="TxtTo" />

                            <TextBlock Text="CC (opcional, separados por ; o ,)" />
                            <TextBox x:Name="TxtCc" />

                            <Button Content="Enviar correos" Click="SendEmails_Click" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2" Background="#FDFDFD" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Vista previa de datos extraidos" FontSize="22" FontWeight="SemiBold" Foreground="#0F766E" />
                        <TextBlock Text="Revisa los valores antes de enviar los correos." Foreground="#57534E" Margin="0,4,0,10" />
                    </StackPanel>

                    <DataGrid x:Name="RecordsGrid" ItemsSource="{Binding Records}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Archivo" Binding="{Binding FileName}" Width="2*" />
                            <DataGridTextColumn Header="Ticket" Binding="{Binding TicketNumber}" Width="*" />
                            <DataGridTextColumn Header="Paquete" Binding="{Binding PackageName}" Width="2*" />
                            <DataGridTextColumn Header="Responsable" Binding="{Binding RequesterName}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
